1070. Product Sales Analysis III

with cte as(
select 
    product_id, 
    min(year) as first_year 
from sales
group by product_id)
select 
    cte.product_id,
    cte.first_year,
    sales.quantity,
    sales.price
from cte left join sales 
on 
cte.product_id = sales.product_id and 
cte.first_year=sales.year ;

