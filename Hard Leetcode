## 1321. Restaurant Growth

# Write your MySQL query statement below
with temp as(
select  distinct visited_on, sum(amount) over(order by visited_on range between interval 6 day preceding and current row ) as amount,
round(sum(amount) over(order by visited_on range between interval 6 day preceding and current row )/7,2) as average_amount

from customer
order by visited_on )

#then select from CTE temp as follow ** 
select * from temp
where visited_on - interval 6 day >= (select min(visited_on) from customer)
